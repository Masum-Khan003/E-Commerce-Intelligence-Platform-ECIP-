# Copy to .env.local for local development. Never commit .env.local.
# Both vars are server-side only (no NEXT_PUBLIC_ prefix) — the BFF proxy
# at app/api/bff/[...path]/route.ts is the only code that reads them.

ECIP_API_URL=http://localhost:8000
ECIP_API_KEY=your-dev-api-key-from-create_api_key.py
